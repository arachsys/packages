require bison flex

check() {
  url https://bird.nic.cz/get-bird/
  match version 2.18.1 'bird-(2\.[0-9.]+)\.tar'
}

prepare() {
  unpack https://bird.nic.cz/download/bird-2.18.1.tar.gz
  apply history.diff
  tree e32e96c4216b5002dab27eed2715166d1cc8412f3a0a1b3df35b280565772187
}

build() {
  auto-config
  make install DESTDIR=/dst
}
