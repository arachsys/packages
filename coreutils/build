check() {
  url https://ftp.gnu.org.uk/gnu/coreutils/
  match version 9.11 'coreutils-([0-9.]+)\.tar'
}

prepare() {
  unpack https://ftp.gnu.org.uk/gnu/coreutils/coreutils-9.11.tar.xz
  apply fmt.diff
  tree 3be5be682644ace614efbea9cb106b1b41601fc4abc519c50814723446df5983
}

build() {
  FORCE_UNSAFE_CONFIGURE=1 auto-config --enable-install-program=hostname \
    --enable-no-install-program=hostid,kill,pinky,uptime,users,who \
    --disable-manual-url
  make install DESTDIR=/dst
}
