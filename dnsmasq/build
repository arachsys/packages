check() {
  url https://thekelleys.org.uk/dnsmasq/
  match version 2.93 'dnsmasq-([0-9.]+)\.tar'
}

prepare() {
  unpack https://thekelleys.org.uk/dnsmasq/dnsmasq-2.93.tar.xz
  apply dhcp6.diff
  tree c4559ff146fb1aedd4d537c2a09f755e89922e510a9c446837ccdadcbd47263c
}

build() {
  make COPTS+='-DLEASEFILE=\"/var/lib/dnsmasq.leases\"' \
       COPTS+='-DRUNFILE=\"/run/dnsmasq.pid\"' \
       DESTDIR=/dst BINDIR=/bin MANDIR=/lib/man install
}
