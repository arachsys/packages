check() {
  url https://thekelleys.org.uk/dnsmasq/
  match version 2.92 'dnsmasq-([0-9.]+)\.tar'
}

prepare() {
  unpack https://thekelleys.org.uk/dnsmasq/dnsmasq-2.92rel2.tar.xz
  apply dhcp6.diff
  tree 700fd27251b035f34f675e731b26b68be8b3c82eee51eda39f8e2099eeb9cd1d
}

build() {
  make COPTS+='-DLEASEFILE=\"/var/lib/dnsmasq.leases\"' \
       COPTS+='-DRUNFILE=\"/run/dnsmasq.pid\"' \
       DESTDIR=/dst BINDIR=/bin MANDIR=/lib/man install
}
