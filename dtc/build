require bison flex m4

check() {
  url https://github.com/dgibson/dtc/tags
  match version 1.8.1 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack dtc-1.8.1.tar.gz \
    https://github.com/dgibson/dtc/archive/refs/tags/v1.8.1.tar.gz
  apply noise.diff
  apply tidy.diff
  tree 273526582a64fbcadbe8fe57e126c39c3f8d4d8c0e14633abc53bb591468a240
}

build() {
  make install DESTDIR=/dst PREFIX= INCLUDEDIR=/lib/include \
    INSTALL=install NO_YAML=1 PKG_CONFIG=false WARNINGS=-Wall
}
