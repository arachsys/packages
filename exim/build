require sqlite

check() {
  url https://downloads.exim.org/exim4/
  match version 4.99.2 'exim-([0-9.]+)\.tar'
}

prepare() {
  unpack https://downloads.exim.org/exim4/exim-4.99.2.tar.xz
  apply config.diff
  apply exepath.diff
  apply libressl.diff
  apply logs.diff
  apply lsearch.diff
  apply paths.diff
  apply uidgid.diff
  tree 28d0079085cdb5656b7d07656284bfcf0df84f29f222a9a4ef254ef3d6db1a6b
}

build() {
  make makefile
  make -C build-* exim PREFIX=
  install -s -t /dst/bin -D build-*/exim
  image - requires sqlite
}
