require sqlite

check() {
  url https://downloads.exim.org/exim4/
  match version 4.99.4 'exim-([0-9.]+)\.tar'
}

prepare() {
  unpack https://downloads.exim.org/exim4/exim-4.99.4.tar.xz
  apply config.diff
  apply exepath.diff
  apply libressl.diff
  apply logs.diff
  apply lsearch.diff
  apply paths.diff
  apply uidgid.diff
  tree 749df82435fcca39d1b869a1a267c04d7412d27bce499f2ed345a42350bb26df
}

build() {
  make makefile
  make -C build-* exim PREFIX=
  install -s -t /dst/bin -D build-*/exim
  image - requires sqlite
}
