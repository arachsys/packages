require sqlite

check() {
  url https://downloads.exim.org/exim4/
  match version 4.99.4 'exim-([0-9.]+)\.tar'
}

prepare() {
  unpack https://downloads.exim.org/exim4/exim-4.99.4.tar.xz
  apply config.diff
  apply exepath.diff
  apply libressl.diff
  apply logs.diff
  apply lsearch.diff
  apply modesty.diff
  apply paths.diff
  apply uidgid.diff
  tree 1a7fb4e47b6f638821e71e93fc1f466b9079ef6da65dc9b27d1a7f9de766a5f3
}

build() {
  make makefile
  make -C build-* exim PREFIX=
  install -s -t /dst/bin -D build-*/exim
  image - requires sqlite
}
