require sqlite

check() {
  url https://downloads.exim.org/exim4/
  match version 4.99.5 'exim-([0-9.]+)\.tar'
}

prepare() {
  unpack https://downloads.exim.org/exim4/exim-4.99.5.tar.xz
  apply config.diff
  apply exepath.diff
  apply libressl.diff
  apply logs.diff
  apply lsearch.diff
  apply modesty.diff
  apply paths.diff
  apply uidgid.diff
  tree 782e3012d5b2c9e51337519b5a256a4ad108ecbd790cfb6c408ac2fc5a5315aa
}

build() {
  make makefile
  make -C build-* exim PREFIX=
  install -s -t /dst/bin -D build-*/exim
  image - requires sqlite
}
