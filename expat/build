check() {
  url https://github.com/libexpat/libexpat/tags
  match version 2.7.5 'tags/R_([0-9]+)_([0-9]+)_([0-9]+)\.tar' '\1.\2.\3'
}

prepare() {
  unpack https://github.com/libexpat/libexpat/releases/download/R_2_7_5/expat-2.7.5.tar.xz
  tree 16df3f930791207e021e5212ac20e2440cbcce0515f59fd55eb683815d3dcb2d
}

build() {
  auto-config LDFLAGS=-Wl,--as-needed,-lunwind
  make install DESTDIR=/dst
  rm -f -r /dst/lib/cmake
}
