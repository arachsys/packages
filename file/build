check() {
  url https://astron.com/pub/file/
  match version 5.48 'file-([0-9.]+)\.tar'
}

prepare() {
  unpack https://astron.com/pub/file/file-5.48.tar.gz
  apply paths.diff
  tree 8a48be3d192ab2e69e0aa90232b1a19e0f5cb2fee705f06dafd485e73b24ed96
}

build() {
  auto-config
  make install DESTDIR=/dst
}
