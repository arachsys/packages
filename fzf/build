require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.74.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.74.0.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.74.0.tar.gz
  go mod vendor
  tree 1843066724c3a08b8fef0e82431756de5653539e7ce20b5aa3588496a57682bf
}

build() {
  go build -ldflags "-s -w -X main.version=0.74.0 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
