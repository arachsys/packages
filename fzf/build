require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.72.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.72.0.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.72.0.tar.gz
  go mod vendor
  tree 68bb783d77d2c216edc7175345857b12beeaca246a879584f3139f98b64b6d61
}

build() {
  go build -ldflags "-s -w -X main.version=0.72.0 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
