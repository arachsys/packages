require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.71.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.71.0.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.71.0.tar.gz
  go mod vendor
  tree e8c81d244a32e7d386c4bfb055469b796395bef1b6bb736f50040662c6e2398d
}

build() {
  go build -ldflags "-s -w -X main.version=0.71.0 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
