require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.74.1 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.74.1.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.74.1.tar.gz
  go mod vendor
  tree 06ded475ca17013d66ef853a804704a1289d6238aea87e7cc86ee745fbeccf3a
}

build() {
  go build -ldflags "-s -w -X main.version=0.74.1 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
