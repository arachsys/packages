require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.70.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.70.0.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.70.0.tar.gz
  go mod vendor
  tree 0089536db02c1d215a57cd85dd87cb9eb8d44b9c410b48b13905315986c6dee7
}

build() {
  go build -ldflags "-s -w -X main.version=0.70.0 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
