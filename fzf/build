require go

check() {
  url https://github.com/junegunn/fzf/tags
  match version 0.73.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack fzf-0.73.0.tar.gz \
    https://github.com/junegunn/fzf/archive/refs/tags/v0.73.0.tar.gz
  go mod vendor
  tree 69d3cdb2c7be8e34fa2eaaa41e1868e039549cc02631020f0aaeeda966670980
}

build() {
  go build -ldflags "-s -w -X main.version=0.73.0 -X main.revision=arachsys"
  install -D fzf /dst/bin/fzf
}
