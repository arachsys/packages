require rust

check() {
  url https://github.com/cloud-hypervisor/cloud-hypervisor/tags
  match version 52.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack cloud-hypervisor-52.0.tar.xz \
    https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/v52.0/cloud-hypervisor-v52.0.tar.xz
  apply cosmetic.diff
  apply discard.diff
  apply hotplug.diff
  apply mmio.diff
  apply rawimg.diff
  apply tapip.diff
  tree b467606280c35eb5f35acc34f22df45c0a85a00b77ca731b18f78891307a5f63
}

build() {
  cargo build --bin=cloud-hypervisor --release
  install -s -D target/release/cloud-hypervisor /dst/bin/hypervisor
}
