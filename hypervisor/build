require rust

check() {
  url https://github.com/cloud-hypervisor/cloud-hypervisor/tags
  match version 53.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack cloud-hypervisor-53.0.tar.xz \
    https://github.com/cloud-hypervisor/cloud-hypervisor/releases/download/v53.0/cloud-hypervisor-v53.0.tar.xz
  apply cosmetic.diff
  apply rawimg.diff
  apply tapip.diff
  tree 9adfc834311d7f789d65be4a76e395f28708c97a782bf5ee829a81c5477c50be
}

build() {
  cargo build --bin=cloud-hypervisor --release
  install -s -D target/release/cloud-hypervisor /dst/bin/hypervisor
}
