check() {
  url https://github.com/arachsys/init/tags
  match version 2.21 'init-([0-9.]+)\.tar'
}

prepare() {
  unpack https://github.com/arachsys/init/archive/init-2.21.tar.gz
  apply sync.diff
  tree 0c1dbfe0b2b9ffd3ba9f78aa3c86a71dc5605cd207556d487944946dd1b73b44
}

build() {
  make install CC=cc DESTDIR=/dst PREFIX=
  cp /src/examples/bin/* /dst/bin/
}
