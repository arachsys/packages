check() {
  url https://codeberg.org/ipmitool/ipmitool/tags
  match version 1.8.19 'archive/IPMITOOL_([0-9]+)_([0-9]+)_([0-9]+)\.tar' '\1.\2.\3'
}

prepare() {
  unpack ipmitool-20260330.tar.gz \
    https://codeberg.org/ipmitool/ipmitool/archive/d62a996c.tar.gz
  apply console.diff
  apply lanplus.diff
  apply warnings.diff
  tree 7d79b665f296b52c4e613b8647c6b18511689a179861ce085f401d1d542088ff
}

build() {
  cp /pkg/config.h include/config.h

  cc -DHAVE_CONFIG_H -DVERSION=\"1.8.19\" -I include -O2 -Wno-format \
    -Wno-pointer-sign -o ipmitool src/ipmitool.c src/ipmishell.c lib/*.c \
    src/plugins/{lan/,lanplus/,open/,}/*.c -lcrypto -lreadline

  install -s -t /dst/bin -D ipmitool
}
