require bison flex

check() {
  url https://www.kernel.org/pub/linux/utils/net/iproute2/
  match version 7.0.0 'iproute2-([0-9.]+)\.tar'
}

prepare() {
  unpack https://www.kernel.org/pub/linux/utils/net/iproute2/iproute2-7.0.0.tar.xz
  apply headers.diff
  apply nocompat.diff
  apply paths.diff
  apply unspec.diff
  tree 8d83994d18cc96672fd7694638976c6ce30d4f61f63c92d5dc2520c36c709a96
}

build() {
  CC=cc PKG_CONFIG=/bin/false /src/configure --prefix= --color=auto
  make install CC=cc DESTDIR=/dst
  sed -e 's/#.*//' -e 's/[[:blank:]]\+/ /g' -e 's/^ //' -e 's/ $//' \
      -e '/^$/d' -i /dst/lib/{iproute2,tc}/*
  rm -f -r /dst/bin/{ifcfg,routef,routel,rtpr} /dst/lib/bash-completion
}
