require bison flex

check() {
  url https://www.kernel.org/pub/linux/utils/net/iproute2/
  match version 7.1.0 'iproute2-([0-9.]+)\.tar'
}

prepare() {
  unpack https://www.kernel.org/pub/linux/utils/net/iproute2/iproute2-7.1.0.tar.xz
  apply nocompat.diff
  apply paths.diff
  apply unspec.diff
  tree 85f7024b8288454dd2f556158865a8f37847b9c477ce2b71882c04ae3dbc4d04
}

build() {
  CC=cc PKG_CONFIG=/bin/false /src/configure --prefix= --color=auto
  make install CC=cc DESTDIR=/dst
  sed -e 's/#.*//' -e 's/[[:blank:]]\+/ /g' -e 's/^ //' -e 's/ $//' \
      -e '/^$/d' -i /dst/lib/{iproute2,tc}/*
  rm -f -r /dst/bin/{ifcfg,routef,routel,rtpr} /dst/lib/bash-completion
}
