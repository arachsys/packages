check() {
  url https://github.com/jqlang/jq/tags
  match version 1.8.2 'tags/jq-([0-9.]+)\.tar'
}

prepare() {
  unpack https://github.com/jqlang/jq/releases/download/jq-1.8.2/jq-1.8.2.tar.gz
  tree 06ac0c434e8e3cb8e1eb656a472921521a243f3dfac9e85680cf94d8a8e0294c
}

build() {
  auto-config --disable-shared
  make all
  install -s -t /dst/bin -D jq
}
