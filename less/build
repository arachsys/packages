check() {
  url http://www.greenwoodsoftware.com/less/download.html
  match version 704 'less-([0-9.]+)\.tar'
}

prepare() {
  unpack http://www.greenwoodsoftware.com/less/less-704.tar.gz
  tree 1e49d3e3335c644c6a74baf808cc60354acbc25dc8d4b5dbf976f36d2f41260f
}

build() {
  auto-config --libexecdir='${prefix}/bin' --with-regex=pcre2
  sed -i '/#define LESSHISTFILE/s/".*"/"-"/' defines.h
  make install DESTDIR=/dst
  rm -f /dst/bin/less{key,-osc8-open} /dst/lib/man/man1/lesskey.1
  ln -s less /dst/bin/more
}
