check() {
  url https://github.com/libarchive/libarchive/tags
  match version 3.8.7 'v([0-9.]+)\.tar'
}

prepare() {
  unpack libarchive-3.8.7.tar.xz \
    https://github.com/libarchive/libarchive/releases/download/v3.8.7/libarchive-3.8.7.tar.xz
  apply cosmetic.diff
  tree bb88fece993ed01887394ff485da134ca2220d0c9a181979e3500c72a32884ca
}

build() {
  auto-config --disable-acl --enable-bsd{cat,cpio,tar}=dynamic \
    --enable-xattr --without-{expat,xml2} --with-{bz2lib,lzma,zlib,zstd}
  make install DESTDIR=/dst
  mv /dst/bin/{bsdcpio,cpio}
  mv /dst/bin/{bsdtar,tar}
}
