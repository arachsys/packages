check() {
  url https://github.com/libarchive/libarchive/tags
  match version 3.8.6 'v([0-9.]+)\.tar'
}

prepare() {
  unpack libarchive-3.8.6.tar.xz \
    https://github.com/libarchive/libarchive/releases/download/v3.8.6/libarchive-3.8.6.tar.xz
  apply cosmetic.diff
  tree 65b0cbebe3011f422dd597719d496f00977015e8a8ab1764b2e1e1a3df594d72
}

build() {
  auto-config --disable-acl --enable-bsd{cat,cpio,tar}=dynamic \
    --enable-xattr --without-{expat,xml2} --with-{bz2lib,lzma,zlib,zstd}
  make install DESTDIR=/dst
  mv /dst/bin/{bsdcpio,cpio}
  mv /dst/bin/{bsdtar,tar}
}
