check() {
  url https://thrysoee.dk/editline/
  match version 20260508-3.1 'libedit-([-0-9.]+)\.tar'
}

prepare() {
  unpack https://thrysoee.dk/editline/libedit-20260508-3.1.tar.gz
  apply config.diff
  apply musl.diff
  tree e8c2bbac534b6045c3d2bd47a654a2ada4bdf4363c16dfbb0c0fa86db02965c4
}

build() {
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/lib/{include/editline/readline.h,libedit.so}
  echo 'INPUT ( libedit.a libncurses.so )' >/dst/lib/libedit.so
}
