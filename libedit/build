check() {
  url https://thrysoee.dk/editline/
  match version 20260512-3.1 'libedit-([-0-9.]+)\.tar'
}

prepare() {
  unpack https://thrysoee.dk/editline/libedit-20260512-3.1.tar.gz
  apply config.diff
  apply musl.diff
  tree 43c39893a5b31022ea357fb40f20d45a4a56670fe3b7e24c2813f04d45422caf
}

build() {
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/lib/{include/editline/readline.h,libedit.so}
  echo 'INPUT ( libedit.a libncurses.so )' >/dst/lib/libedit.so
}
