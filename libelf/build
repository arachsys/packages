check() {
  url https://github.com/arachsys/libelf/tags
  match version 0.195 'tags/v([0-9.]+)\.tar'

  url https://sourceware.org/git/\?p=elfutils.git
  match 'upstream elfutils' 0.195 'elfutils-([0-9.]+)'
}

prepare() {
  unpack libelf-0.195.tar.gz \
    https://github.com/arachsys/libelf/archive/refs/tags/v0.195.tar.gz
  tree 600c10cadcff4a9146f0dec83c56dff8a2acb1d79e680fc3b837d33bff27e2e9
}

build() {
  make install DESTDIR=/dst INCDIR=/lib/include
}
