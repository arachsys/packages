check() {
  url https://github.com/libevent/libevent/tags
  match version 2.1.13 'releases/tag/release-([0-9.]+)-stable'
}

prepare() {
  unpack libevent-2.1.13.tar.gz \
    https://github.com/libevent/libevent/releases/download/release-2.1.13-stable/libevent-2.1.13-stable.tar.gz
  apply libressl.diff
  tree 0c203b20ee251eb25b9ad9771e72ea826856fcbdeb08d7a7b1e5cfe9bbe06219
}

build() {
  sed -i '/GENERIC_LDFLAGS =/s/\$(RELEASE) //p' Makefile.{am,in}
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/bin/event_rpcgen.py
}
