require lua

check() {
  url https://www.lighttpd.net/
  match version 1.4.85 'lighttpd-([0-9.]+).tar'
}

prepare() {
  unpack lighttpd-1.4.85.tar.xz \
    https://download.lighttpd.net/lighttpd/releases-1.4.x/lighttpd-1.4.85.tar.xz
  apply paths.diff
  tree 1553cc4726aab50e0ffe61ff3020d70afc49d42c41da1dcf0e37a3ead08b78ab
}

build() {
  cp /pkg/config.h src
  cd src

  cc -O2 -o lemon lemon.c
  $PWD/lemon -q configparser.y

  LIGHTTPD_VERSION=1.4.85
  IFS=. read -r MAJOR MINOR PATCH <<< "$LIGHTTPD_VERSION"
  set -- -DHAVE_CONFIG_H -DPACKAGE_VERSION=\"$LIGHTTPD_VERSION\" \
    -DLIGHTTPD_VERSION_ID=$((65536*10#$MAJOR+ 256*10#$MINOR + 10#$PATCH))

  cc "$@" -I . -O2 -Wall -Wl,--export-dynamic -o lighttpd \
    !(lemon|lempar|lighttpd-angel|mod_*|vector|*_win32).c ls-hpack/*.c \
    mod_{access,alias,evhost,expire,fastcgi,indexfile,redirect,rewrite}.c \
    mod_{scgi,setenv,simple_vhost,staticfile}.c -lcrypto -lpcre2-8

  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_accesslog.so -o mod_accesslog.so mod_accesslog.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_auth.so -o mod_auth.so mod_auth{,_api}.c -lcrypto
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_authn_file.so -o mod_authn_file.so mod_authn_file.c -lcrypto
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_cgi.so -o mod_cgi.so mod_cgi.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_deflate.so -o mod_deflate.so mod_deflate.c -lz -lzstd
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_dirlisting.so -o mod_dirlisting.so mod_dirlisting.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_extforward.so -o mod_extforward.so mod_extforward.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_openssl.so -o mod_openssl.so mod_openssl.c -lssl
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_magnet.so -o mod_magnet.so mod_magnet{,_cache}.c -llua
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_proxy.so -o mod_proxy.so mod_proxy.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_sockproxy.so -o mod_sockproxy.so mod_sockproxy.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_ssi.so -o mod_ssi.so mod_ssi.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_status.so -o mod_status.so mod_status.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_userdir.so -o mod_userdir.so mod_userdir.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_webdav.so -o mod_webdav.so mod_webdav.c
  cc "$@" -I . -O2 -Wall -fPIC -shared -Wl,-soname \
    -Wl,mod_wstunnel.so -o mod_wstunnel.so mod_wstunnel.c

  install -s -t /dst/bin -D lighttpd
  install -s -t /dst/lib/lighttpd -D mod_*.so
}
