check() {
  url https://github.com/LMDB/lmdb/tags
  match version 1.0.0 'LMDB_([0-9.]+)\.tar'
}

prepare() {
  unpack -p 3 lmdb-1.0.0.tar.gz \
    https://github.com/LMDB/lmdb/archive/refs/tags/LMDB_1.0.0.tar.gz
  tree 669a939a44b5f3a7a4ffc76a68c28c270ed99c937bbfbfeb4cecc6661f092c4b
}

build() {
  make CC=cc all
  mkdir -p /dst/lib/{include,shared,static}
  cp lmdb.h /dst/lib/include/lmdb.h
  cp liblmdb.a /dst/lib/static/liblmdb.a
  cp -P liblmdb.so liblmdb.so.* /dst/lib/shared
}
