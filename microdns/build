check() {
  url https://api.github.com/repos/arachsys/microdns/branches/master
  match snapshot 20260628 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack microdns-20260628-e75aaaca.tar.gz \
    https://github.com/arachsys/microdns/archive/e75aaaca.tar.gz
  tree 58b5df79cbee910067797eccadcedbf6b69f87cabdde650669d89ed94b5ecae2
}

build() {
  make install DESTDIR=/dst $(enabled static && echo LDFLAGS+=-static)
}
