enable setuid

check() {
  url https://github.com/traviscross/mtr/tags
  match version 0.96 'v([0-9.]+)\.tar'
}

prepare() {
  unpack mtr-0.96.tar.gz \
    https://github.com/traviscross/mtr/archive/refs/tags/v0.96.tar.gz
  apply cosmetic.diff
  apply prune.diff
  tree aefa0e6d0a30f8d6f1a6467278e628dc3dc88e79ca5f2166b924898a2d307cef
}

build() {
  cp /pkg/config.h config.h

  cc -DPACKAGE_VERSION=\"0.96\" -I . -O2 -Wall -Wno-pointer-sign \
    -o mtr ui/!(gtk).c packet/cmdparse.c packet/sockaddr.c \
    portability/error.c -lncursesw

  cc -DPACKAGE_VERSION=\"0.96\" -I . -O2 -Wall -Wno-pointer-sign \
    -o mtr-packet packet/!(*_cygwin).c portability/error.c

  install -s -t /dst/bin -D mtr mtr-packet
  chmod u+s /dst/bin/mtr-packet
}
