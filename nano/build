check() {
  url https://ftp.gnu.org.uk/gnu/nano/
  match version 9.1 'nano-([0-9.]+)\.tar'
}

prepare() {
  unpack https://ftp.gnu.org.uk/gnu/nano/nano-9.1.tar.xz
  tree 3f9ade8a3c0eeaac6f2f5841bc7a6ec95d67bf88c3570e7c48f4efede80494e9
}

build() {
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/bin/rnano
}
