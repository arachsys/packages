check() {
  url https://www.nano-editor.org/dist/latest/
  match version 9.0 'nano-([0-9.]+)\.tar'
}

prepare() {
  unpack https://www.nano-editor.org/dist/v9/nano-9.0.tar.xz
  tree 613eeac6ff696ee9256b379cad4901ca8a037236c2723b12b1797cd4ab081c8b
}

build() {
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/bin/rnano
}
