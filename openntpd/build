require bison

check() {
  url https://github.com/arachsys/openntpd/tags
  match version 7.9.0 'openntpd-([0-9.]+)\.tar'

  url https://www.openbsd.org/
  match 'upstream openbsd' 7.9 'OpenBSD ([0-9.]+)'
}

prepare() {
  unpack https://github.com/arachsys/openntpd/archive/openntpd-7.9.0.tar.gz
  tree ea284b40cc444f2f63a8f35bd15eedc11ed40eabc82acb7651d77a9edc27bc18
}

build() {
  make install DESTDIR=/dst
}
