check() {
  url https://www.sqlite.org/index.html
  match version 3.53.3 'Version ([0-9.]*[0-9])'
}

prepare() {
  unpack sqlite-3.53.3.tar.gz \
    https://www.sqlite.org/2026/sqlite-autoconf-3530300.tar.gz
  tree bc77bde4acc947c87000438328609b4dcf02a50c397f73b6e46a29a14fc896f8
}

build() {
  /src/configure --prefix= --all --disable-static-shell
  make install DESTDIR=/dst LDFLAGS.rpath= datadir='${prefix}/lib' \
    includedir='${prefix}/lib/include'
}
