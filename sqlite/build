check() {
  url https://www.sqlite.org/index.html
  match version 3.52.0 'Version ([0-9.]*[0-9])'
}

prepare() {
  unpack sqlite-3.52.0.tar.gz \
    https://www.sqlite.org/2026/sqlite-autoconf-3520000.tar.gz
  tree 44178925e948705a555b2a4170ce2975470d02d48100e2823b18c9441060f076
}

build() {
  /src/configure --prefix= --all --disable-static-shell
  make install DESTDIR=/dst LDFLAGS.rpath= datadir='${prefix}/lib' \
    includedir='${prefix}/lib/include'
}
