check() {
  url https://www.sqlite.org/index.html
  match version 3.51.3 'Version ([0-9.]*[0-9])'
}

prepare() {
  unpack sqlite-3.51.3.tar.gz \
    https://www.sqlite.org/2026/sqlite-autoconf-3510300.tar.gz
  tree 73b4f25672aad387b12dfd65f9f68a5349c87ade994df89f3bd57887f374db78
}

build() {
  /src/configure --prefix= --all --disable-static-shell
  make install DESTDIR=/dst LDFLAGS.rpath= datadir='${prefix}/lib' \
    includedir='${prefix}/lib/include'
}
