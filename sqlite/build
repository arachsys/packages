check() {
  url https://www.sqlite.org/index.html
  match version 3.53.0 'Version ([0-9.]*[0-9])'
}

prepare() {
  unpack sqlite-3.53.0.tar.gz \
    https://www.sqlite.org/2026/sqlite-autoconf-3530000.tar.gz
  tree dcbb03442912a03b31efc3d6e3cfa76155fda84bd768f2f0ce141508f72198c7
}

build() {
  /src/configure --prefix= --all --disable-static-shell
  make install DESTDIR=/dst LDFLAGS.rpath= datadir='${prefix}/lib' \
    includedir='${prefix}/lib/include'
}
