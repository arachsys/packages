check() {
  url https://www.sqlite.org/index.html
  match version 3.53.2 'Version ([0-9.]*[0-9])'
}

prepare() {
  unpack sqlite-3.53.2.tar.gz \
    https://www.sqlite.org/2026/sqlite-autoconf-3530200.tar.gz
  tree 3ca4128a710154ea5c09c3b379b9d26e6b3627934b587ee032480ec23e9f5ab5
}

build() {
  /src/configure --prefix= --all --disable-static-shell
  make install DESTDIR=/dst LDFLAGS.rpath= datadir='${prefix}/lib' \
    includedir='${prefix}/lib/include'
}
