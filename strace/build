check() {
  url https://github.com/strace/strace/tags
  match version 7.1 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack https://strace.io/files/7.1/strace-7.1.tar.xz
  tree 8c0378d9a084bd11ec6ab5a3e7e49b49b054456823d211177852d18d8909c34d
}

build() {
  auto-config --disable-gcc-Werror --disable-mpers
  make install DESTDIR=/dst
  rm -f /dst/bin/strace-{graph,log-merge}
}
