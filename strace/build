check() {
  url https://github.com/strace/strace/tags
  match version 7.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack https://strace.io/files/7.0/strace-7.0.tar.xz
  tree 94e924e18a2b9fb190df005292864ebec169ae03386b4e127eb9e2177174c9ab
}

build() {
  auto-config --disable-gcc-Werror --disable-mpers
  make install DESTDIR=/dst
  rm -f /dst/bin/strace-{graph,log-merge}
}
