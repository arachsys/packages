require bison libevent

check() {
  url https://github.com/tmux/tmux/tags
  match version 3.7b 'tags/([0-9.]+[a-z]?)\.tar'
}

prepare() {
  unpack https://github.com/tmux/tmux/releases/download/3.7b/tmux-3.7b.tar.gz
  tree f77743ed0ef035549f76744a6b8dbffe5e4a9c5cb2e79d7c005453809cd1aecd
}

build() {
  auto-config
  sed -i 's/-l\(event[^ ]*\)/-l:lib\1.a/g' Makefile
  make install DESTDIR=/dst
}
