require bison libevent

check() {
  url https://github.com/tmux/tmux/tags
  match version 3.7 'tags/([0-9.]+[a-z]?)\.tar'
}

prepare() {
  unpack https://github.com/tmux/tmux/releases/download/3.7/tmux-3.7.tar.gz
  tree a6108ba3b715d0f2f85d9bcb86f5efa81a669f31539070ec0d722acd1a950cd0
}

build() {
  auto-config
  sed -i 's/-l\(event[^ ]*\)/-l:lib\1.a/g' Makefile
  make install DESTDIR=/dst
}
