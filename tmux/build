require bison libevent

check() {
  url https://github.com/tmux/tmux/tags
  match version 3.6b 'tags/([0-9.]+[a-z]?)\.tar'
}

prepare() {
  unpack https://github.com/tmux/tmux/releases/download/3.6b/tmux-3.6b.tar.gz
  tree f3de7026c68c5535c558029d0477872fe3b3a773fb9cb5230e1673bbf0ed9654
}

build() {
  auto-config
  sed -i 's/-l\(event[^ ]*\)/-l:lib\1.a/g' Makefile
  make install DESTDIR=/dst
}
