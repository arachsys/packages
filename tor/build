require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.10 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.10.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree 6d5ab32e488a676f7263a3cee937057f7fee5a668277bc56f8dae7a0daf8c20f
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
