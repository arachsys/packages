require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.6 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.6.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree f528c006d100569b5b8bd6bc62c96badc92ec726c3ae160bcd2aa9c277387911
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
