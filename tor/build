require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.9 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.9.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree b7e1e28e4f529b9d7ee03ef95c081241909bd732e7bc5e69c3b022a4029d2e01
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
