require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.8 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.8.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree 848fa27485f32de91d877f66226a950c70af90545f671b8f7fd41087134192a1
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
