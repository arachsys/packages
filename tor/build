require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.11 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.11.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree e4c13c48aa4f89e3593217c94c08a84fc145270f27aa2589584f6f1e7d59325e
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
