require libevent

check() {
  url https://dist.torproject.org/
  match version 0.4.9.7 'tor-([0-9.]+)\.tar'
}

prepare() {
  unpack https://dist.torproject.org/tor-0.4.9.7.tar.gz
  apply cosmetic.diff
  apply config.diff
  tree 0da795864078f29ffe90619e589c9aaf83d3f77a23fe48c50c948d5f9cb84fdb
}

build() {
  auto-config --enable-lzma --enable-zstd CONFDIR=/etc \
    CPPFLAGS=-DDISABLE_ENGINES {LZMA,ZSTD}_CFLAGS=-I/lib/include \
    LZMA_LIBS=-llzma ZSTD_LIBS=-lzstd
  sed -i 's/-levent/-l:libevent.a/g' Makefile
  make install DESTDIR=/dst
  rm -f /dst/bin/torify
}
