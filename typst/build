require rust

check() {
  url https://github.com/typst/typst/tags
  match version 0.15.1 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack typst-0.15.1.tar.gz \
    https://github.com/typst/typst/archive/refs/tags/v0.15.1.tar.gz
  cargo vendor >>.cargo/config.toml
  apply cosmetic.diff
  tree 3d713d3f57e649ce78f6bf6cb54f6e699b55af466ea52506d9bf8ce9ea0f1195
}

build() {
  OPENSSL_INCLUDE_DIR=/lib/include OPENSSL_LIB_DIR=/lib/shared \
    cargo build --release
  install -t /dst/bin -D target/release/typst
}
