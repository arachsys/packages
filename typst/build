require rust

check() {
  url https://github.com/typst/typst/tags
  match version 0.15.0 'tags/v([0-9.]+)\.tar'
}

prepare() {
  unpack typst-0.15.0.tar.gz \
    https://github.com/typst/typst/archive/refs/tags/v0.15.0.tar.gz
  cargo vendor >>.cargo/config.toml
  apply cosmetic.diff
  tree a5fdd0cb14652aaaa6124f0e8e583885c98b9a02854d737772a393a324e2bc07
}

build() {
  OPENSSL_INCLUDE_DIR=/lib/include OPENSSL_LIB_DIR=/lib/shared \
    cargo build --release
  install -t /dst/bin -D target/release/typst
}
