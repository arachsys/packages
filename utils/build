enable setuid

check() {
  url https://api.github.com/repos/arachsys/arachsys-utils/branches/master
  match snapshot 20260603 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack arachsys-utils-20260603-5a17ea17.tar.gz \
    https://github.com/arachsys/arachsys-utils/archive/5a17ea17.tar.gz
  tree e658a732671a5d8c44d066f9599d6764aa33c797cdd2cda16197a4f4676ac4c7
}

build() {
  make -C host install DESTDIR=/img/host-utils
  make -C user install DESTDIR=/img/user-utils
}
