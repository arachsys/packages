enable setuid

check() {
  url https://api.github.com/repos/arachsys/arachsys-utils/branches/master
  match snapshot 20260620 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack arachsys-utils-20260620-597fe0f7.tar.gz \
    https://github.com/arachsys/arachsys-utils/archive/597fe0f7.tar.gz
  tree 2b820e7a2460d4d8f7db1edc9ad0a2e63193ab23ba91226d6cc0cbaada9bf57e
}

build() {
  make -C host install DESTDIR=/img/host-utils
  make -C user install DESTDIR=/img/user-utils
}
