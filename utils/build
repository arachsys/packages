enable setuid

check() {
  url https://api.github.com/repos/arachsys/arachsys-utils/branches/master
  match snapshot 20260228 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack arachsys-utils-20260228-ee043f13.tar.gz \
    https://github.com/arachsys/arachsys-utils/archive/ee043f13.tar.gz
  tree c0318f9c7bb3d18a77e23ddec996957c2e108aef47af4df5d0b2f44c67b55a3f
}

build() {
  make -C host install DESTDIR=/img/host-utils
  make -C user install DESTDIR=/img/user-utils
}
