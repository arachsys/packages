enable setuid

check() {
  url https://api.github.com/repos/arachsys/arachsys-utils/branches/master
  match snapshot 20260525 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack arachsys-utils-20260525-c4843d97.tar.gz \
    https://github.com/arachsys/arachsys-utils/archive/c4843d97.tar.gz
  tree f2fd6f3953c0b6bf2fa494674e51f56d170cc1bb2bc01e91d15db7eeaccd30f3
}

build() {
  make -C host install DESTDIR=/img/host-utils
  make -C user install DESTDIR=/img/user-utils
}
