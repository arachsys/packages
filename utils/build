enable setuid

check() {
  url https://api.github.com/repos/arachsys/arachsys-utils/branches/master
  match snapshot 20260604 \
    '"date": *"([0-9]{4})-([0-9]{2})-([0-9]{2})' '\1\2\3'
}

prepare() {
  unpack arachsys-utils-20260604-4342c03c.tar.gz \
    https://github.com/arachsys/arachsys-utils/archive/4342c03c.tar.gz
  tree 0a3fb6ef4d7645d9654afe5532f17b56589a49b3e168f50803f3a594d2998c57
}

build() {
  make -C host install DESTDIR=/img/host-utils
  make -C user install DESTDIR=/img/user-utils
}
