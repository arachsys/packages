check() {
  url https://github.com/vim/vim/tags
  match version '9.2.03??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0301.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0301.tar.gz
  apply paths.diff
  tree 930425693b35a95350ccd2aa879605f60c05d6286b9d533a8ad42b93910b11de
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
