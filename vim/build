check() {
  url https://github.com/vim/vim/tags
  match version '9.2.05??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0500.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0500.tar.gz
  apply paths.diff
  tree 62a12c0768ba84959660e7bdf09caceb378b80c7e802f490f5918a2b4e063477
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
