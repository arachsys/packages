check() {
  url https://github.com/vim/vim/tags
  match version '9.2.01??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0106.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0106.tar.gz
  apply paths.diff
  tree 92f9cb2dccb5b872c4ee8f16f53a88a9d865ee717c12d755ef5eacd7b43dbfd7
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
