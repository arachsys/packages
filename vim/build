check() {
  url https://github.com/vim/vim/tags
  match version '9.2.04??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0404.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0404.tar.gz
  apply paths.diff
  tree ea4424b6ab8e851d6f3dbc8e6e813bd0d4e8ea2302990518dee75700a40d5c55
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
