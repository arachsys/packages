check() {
  url https://github.com/vim/vim/tags
  match version '9.2.02??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0200.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0200.tar.gz
  apply paths.diff
  tree 4817e379be0e90457b997337d1787560a3a0216c1084b5586a9b43d78ed2f072
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
