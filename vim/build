check() {
  url https://github.com/vim/vim/tags
  match version '9.2.06??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0600.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0600.tar.gz
  apply paths.diff
  tree dc4a0509821c87b9acc265219c75356cb62adc1984283f7f4586c5f838b874f4
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
