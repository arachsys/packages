check() {
  url https://github.com/vim/vim/tags
  match version '9.2.08??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0803.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0803.tar.gz
  apply paths.diff
  tree 04837334d4f7b228ee3043827db0179492b01a73c9cfae850a95cc0bfdfb6925
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
