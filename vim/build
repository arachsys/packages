check() {
  url https://github.com/vim/vim/tags
  match version '9.2.07??' 'v([0-9.]+)\.tar'
}

prepare() {
  unpack vim-9.2.0706.tar.gz \
    https://github.com/vim/vim/archive/refs/tags/v9.2.0706.tar.gz
  apply paths.diff
  tree 546b4f483d9c36d3f3cd987dba738f50767e57637e83e9e78be84226a7ec0f90
}

build() {
  auto-config --enable-{multibyte,terminal} --without-local-dir
  make install DESTDIR=/dst VIMRTLOC=/lib/vim
  ln -s vim /dst/bin/vi
  rm -r /dst/bin/vimtutor /dst/lib/{applications,icons} \
    /dst/lib/vim/{**/README.*,*_example.vim,tools}
}
