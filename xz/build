check() {
  url https://github.com/tukaani-project/xz/tags
  match version 5.8.3 'v([0-9.]+)\.tar'
}

prepare() {
  unpack https://github.com/tukaani-project/xz/releases/download/v5.8.3/xz-5.8.3.tar.xz
  tree 4857366488ff3b4b373f95eafd5b4b93999b7392d56abf81a9d8d8e9b0303c70
}

build() {
  auto-config
  make install DESTDIR=/dst
  rm -f /dst/bin/{lz,xz}{cmp,diff,*grep,less,more} \
    /dst/lib/man/man1/{lz,xz}{cmp,diff,*grep,less,more}.1
}
